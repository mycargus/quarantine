    "schemas": {
      "repository": {
        "title": "Repository",
        "description": "A GitHub repository.",
        "type": "object",
        "required": ["id", "full_name", "default_branch", "private"],
        "properties": {
          "id": { "type": "integer", "example": 1296269 },
          "node_id": { "type": "string", "example": "MDEwOlJlcG9zaXRvcnkxMjk2MjY5" },
          "name": { "type": "string", "example": "Hello-World" },
          "full_name": { "type": "string", "example": "octocat/Hello-World" },
          "private": { "type": "boolean" },
          "default_branch": { "type": "string", "example": "main" },
          "description": { "type": "string", "nullable": true }
        }
      },
      "git-ref": {
        "title": "Git Reference",
        "description": "Git references within a repository.",
        "type": "object",
        "required": ["ref", "object"],
        "properties": {
          "ref": { "type": "string", "example": "refs/heads/quarantine/state" },
          "node_id": { "type": "string" },
          "url": { "type": "string" },
          "object": {
            "type": "object",
            "required": ["sha", "type", "url"],
            "properties": {
              "type": { "type": "string", "example": "commit" },
              "sha": { "type": "string", "example": "aa218f56b14c9653891f9e74264a383fa43fefbd" },
              "url": { "type": "string" }
            }
          }
        }
      },
      "content-file": {
        "title": "Content File",
        "description": "Content File",
        "type": "object",
        "required": ["content", "sha"],
        "properties": {
          "type": { "type": "string" },
          "encoding": { "type": "string" },
          "size": { "type": "integer" },
          "name": { "type": "string" },
          "path": { "type": "string" },
          "content": {
            "type": "string",
            "description": "Base64-encoded file content.",
            "example": "eyJ2ZXJzaW9uIjoxLCJ0ZXN0cyI6e319Cg=="
          },
          "sha": {
            "type": "string",
            "description": "The blob SHA of the file, required for CAS writes.",
            "example": "abc123def456abc123def456abc123def456abc1"
          },
          "url": { "type": "string" },
          "git_url": { "type": "string", "nullable": true },
          "html_url": { "type": "string", "nullable": true },
          "download_url": { "type": "string", "nullable": true }
        }
      },
      "file-commit": {
        "title": "File Commit",
        "description": "File Commit",
        "type": "object",
        "properties": {
          "content": {
            "nullable": true,
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "sha": { "type": "string" }
            }
          },
          "commit": {
            "type": "object",
            "properties": {
              "sha": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      },
      "issue-search-result": {
        "title": "Issue Search Result Item",
        "description": "Issue Search Result",
        "type": "object",
        "required": ["total_count", "incomplete_results", "items"],
        "properties": {
          "total_count": { "type": "integer" },
          "incomplete_results": { "type": "boolean" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/issue-search-item" }
          }
        }
      },
      "issue-search-item": {
        "title": "Issue Search Item",
        "type": "object",
        "required": ["number", "html_url"],
        "properties": {
          "number": { "type": "integer", "example": 1 },
          "html_url": { "type": "string", "example": "https://github.com/octocat/Hello-World/issues/1" },
          "title": { "type": "string" },
          "state": { "type": "string" },
          "body": { "type": "string", "nullable": true },
          "labels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" }
              }
            }
          }
        }
      },
      "issue": {
        "title": "Issue",
        "description": "Issues are a great way to keep track of tasks.",
        "type": "object",
        "required": ["number", "html_url"],
        "properties": {
          "id": { "type": "integer" },
          "node_id": { "type": "string" },
          "number": { "type": "integer", "example": 1 },
          "title": { "type": "string" },
          "state": { "type": "string" },
          "html_url": {
            "type": "string",
            "example": "https://github.com/octocat/Hello-World/issues/1347"
          },
          "body": { "type": "string", "nullable": true },
          "labels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" }
              }
            }
          }
        }
      },
      "issue-comment": {
        "title": "Issue Comment",
        "description": "Comments provide a way for people to collaborate on an issue.",
        "type": "object",
        "required": ["id", "body"],
        "properties": {
          "id": { "type": "integer", "example": 10 },
          "node_id": { "type": "string" },
          "url": { "type": "string" },
          "html_url": { "type": "string" },
          "body": { "type": "string", "example": "Me too" },
          "body_text": { "type": "string" },
          "body_html": { "type": "string" },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      },
      "artifact": {
        "title": "Artifact",
        "description": "An artifact",
        "type": "object",
        "required": ["id", "node_id", "name", "size_in_bytes", "url", "archive_download_url", "expired", "created_at", "expires_at", "updated_at"],
        "properties": {
          "id": { "type": "integer", "example": 5 },
          "node_id": { "type": "string", "example": "MDEwOkNoZWNrU3VpdGU1" },
          "name": { "type": "string", "example": "quarantine-results-12345" },
          "size_in_bytes": { "type": "integer", "example": 12345 },
          "url": { "type": "string" },
          "archive_download_url": {
            "type": "string",
            "example": "https://api.github.com/repos/github/hello-world/actions/artifacts/5/zip"
          },
          "expired": { "type": "boolean" },
          "created_at": { "type": "string", "format": "date-time", "nullable": true },
          "expires_at": { "type": "string", "format": "date-time", "nullable": true },
          "updated_at": { "type": "string", "format": "date-time", "nullable": true },
          "digest": { "type": "string", "nullable": true },
          "workflow_run": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": { "type": "integer" },
              "repository_id": { "type": "integer" },
              "head_repository_id": { "type": "integer" },
              "head_branch": { "type": "string" },
              "head_sha": { "type": "string" }
            }
          }
        }
      },
      "basic-error": {
        "title": "Basic Error",
        "description": "Basic Error",
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "documentation_url": { "type": "string" },
          "url": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "validation-error": {
        "title": "Validation Error",
        "description": "Validation Error",
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": { "type": "string" },
          "documentation_url": { "type": "string" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "resource": { "type": "string" },
                "field": { "type": "string" },
                "code": { "type": "string" },
                "message": { "type": "string" },
                "index": { "type": "integer" }
              }
            }
          }
        }
      }
    },

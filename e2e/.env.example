# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real tokens.

# GitHub PAT with repo scope (read/write contents, issues)
QUARANTINE_GITHUB_TOKEN=ghp_your_token_here

# GitHub owner and repo for the test fixture
QUARANTINE_TEST_OWNER=mycargus
QUARANTINE_TEST_REPO=quarantine-test-fixture

# Optional: path to the quarantine binary (defaults to ../bin/quarantine)
# QUARANTINE_BIN=/path/to/quarantine

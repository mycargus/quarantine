{
  "name": "quarantine-dashboard",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "dev": "node --import tsx/esm app/server.ts",
    "start": "node --import tsx/esm app/server.ts",
    "test": "node --test --import tsx/esm 'app/**/*.test.{ts,tsx}' 'test/*.interface.test.ts'",
    "test:ci": "node --test --test-reporter=dot --import tsx/esm 'app/**/*.test.{ts,tsx}' 'test/*.interface.test.ts'",
    "lint": "biome check",
    "lint:ci": "biome ci --error-on-warnings",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe",
    "typecheck": "tsc --noEmit",
    "seed": "node --import tsx/esm scripts/seed.ts"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.8.0",
    "js-yaml": "^4.1.1",
    "remix": "next"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "riteway": "^9.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}

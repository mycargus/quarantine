{
  "name": "quarantine-dashboard",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "test": "node --test --import tsx 'app/**/*.test.{ts,tsx}'",
    "lint": "biome check",
    "lint:ci": "biome ci --error-on-warnings",
    "lint:fix": "biome check --write",
    "lint:fix:unsafe": "biome check --write --unsafe",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-router/node": "^7.13.2",
    "@react-router/serve": "^7.13.2",
    "adm-zip": "^0.5.16",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.8.0",
    "isbot": "^5.1.0",
    "js-yaml": "^4.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@react-router/dev": "^7.13.2",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "riteway": "^9.2.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.1"
  }
}

{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/reject-secrets-in-files.sh \"$TOOL_INPUT\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/reject-destructive-git.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "mikey@mikey-claude-plugins": true
  },
  "permissions": {
    "allow": [
      "Bash(*--help)",
      "Bash(*--version)",
      "Bash(*-h)",
      "Bash(*-v)",
      "Bash(*version)",
      "Bash(brew list:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(docker pull:*)",
      "Bash(docker restart:*)",
      "Bash(docker rm:*)",
      "Bash(docker stop:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go clean:*)",
      "Bash(go list:*)",
      "Bash(go mod:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(golangci-lint run:*)",
      "Bash(grep:*)",
      "Bash(make -C .. cli-lint)",
      "Bash(make:*)",
      "Bash(mkdir -p:*)",
      "Bash(mv:*)",
      "Bash(pnpm:*)",
      "Bash(rm:*)",
      "Bash(wc -l:*)",
      "Bash(wc:*)",
      "Delete",
      "Edit",
      "Read",
      "Skill(claude-md-management:revise-claude-md)",
      "Skill(verify-milestone)",
      "WebFetch",
      "WebSearch",
      "Write"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(rm -rf:*)"
    ]
  }
}

{
  "name": "quarantine-test",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "vitest run",
    "test:contract": "vitest run --project contract --passWithNoTests",

  "devDependencies": {
    "@biomejs/biome": "1.9.0",
    "@stoplight/prism-cli": "^5.14.2",
    "adm-zip": "^0.5.16",
    "riteway": "^9.2.0",
    "vitest": "^4.1.2"
  }
